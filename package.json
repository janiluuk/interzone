{
  "name": "interzone-dispatcher",
  "version": "1.0.0",
  "description": "Interzone Inference Dispatcher — LAN GPU fleet router",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "npm run build:server && npm run build:dashboard",
    "build:server": "tsc -p tsconfig.server.json",
    "build:dashboard": "vite build --config src/dashboard/vite.config.ts",
    "dev": "concurrently \"tsc -w -p tsconfig.server.json\" \"vite src/dashboard --config src/dashboard/vite.config.ts\" \"nodemon dist/server.js\"",
    "start": "node dist/server.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@fastify/static": "^7.0.0",
    "@fastify/websocket": "^10.0.0",
    "fastify": "^4.28.0",
    "prom-client": "^15.1.3",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.0",
    "nodemon": "^3.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^1.6.0"
  }
}
